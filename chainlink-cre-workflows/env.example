# Copy to chainlink-cre-workflows/.env (project root next to project.yaml).
# CRE_ETH_PRIVATE_KEY must be exactly 64 hex characters, no 0x prefix.
# If you keep secrets only in weekly-prize-distribution/.env instead, pass:
#   -e weekly-prize-distribution/.env
# on each `cre workflow` command.
CRE_ETH_PRIVATE_KEY=

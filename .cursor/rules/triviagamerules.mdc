## Complete Backend Integration

```javascript
// trivia-backend/gameManager.js

const { ethers } = require('ethers');

class TriviaGameManager {
    constructor(contractAddress, provider, signer) {
        this.contract = new ethers.Contract(
            contractAddress,
            TRIVIA_ABI,
            signer
        );
        this.activeGames = new Map(); // Track active games
    }
    
    // Start a new game on-demand
    async createGame() {
        try {
            // Verify no active game
            const canCreate = await this.contract.canCreateNewGame();
            if (!canCreate) {
                throw new Error("Cannot create game - one is already active");
            }
            
            // Create the game
            const tx = await this.contract.createGame();
            const receipt = await tx.wait();
            
            // Get gameId from event
            const event = receipt.events.find(e => e.event === 'GameCreated');
            const gameId = event.args.gameId;
            const endTime = event.args.endTime;
            
            console.log(`✅ Game ${gameId} created`);
            console.log(`⏰ Ends at: ${new Date(endTime * 1000).toLocaleString()}`);
            
            // Schedule ranking submission
            this.scheduleRankingSubmission(gameId, endTime);
            
            return gameId;
            
        } catch (error) {
            console.error("Failed to create game:", error);
            throw error;
        }
    }
    
    // Schedule ranking submission for when game ends
    scheduleRankingSubmission(gameId, endTime) {
        const now = Math.floor(Date.now() / 1000);
        const delay = (endTime - now + 5) * 1000; // 5 seconds after game ends
        
        setTimeout(async () => {
            await this.submitGameResults(gameId);
        }, delay);
        
        console.log(`📅 Scheduled ranking submission for game ${gameId}`);
    }
    
    // Submit results after game ends
    async submitGameResults(gameId) {
        try {
            // Get final scores from your game database
            const playerScores = await this.getPlayerScores(gameId);
            
            if (playerScores.length === 0) {
                console.log(`No players in game ${gameId}`);
                // Still submit empty rankings to allow finalization
                await this.contract.submitRankings(gameId, []);
                return;
            }
            
            // Sort by score (highest first) and take top 10
            const rankedPlayers = playerScores
                .sort((a, b) => b.score - a.score)
                .slice(0, 10)
                .map(p => p.address);
            
            console.log(`Submitting rankings for game ${gameId}...`);
            console.log("Winners:", rankedPlayers);
            
            // Submit to contract
            const tx = await this.contract.submitRankings(gameId, rankedPlayers);
            await tx.wait();
            
            console.log(`✅ Rankings submitted for game ${gameId}`);
            console.log(`⏳ Chainlink will finalize within ~1 minute`);
            
            // Optional: Wait for finalization
            await this.waitForFinalization(gameId);
            
        } catch (error) {
            console.error(`Failed to submit rankings for game ${gameId}:`, error);
            // Alert your team
            await this.sendAlert(`Rankings failed for game ${gameId}`);
        }
    }
    
    // Wait for Chainlink to finalize
    async waitForFinalization(gameId, maxWaitSeconds = 120) {
        const startTime = Date.now();
        const maxWait = maxWaitSeconds * 1000;
        
        while (Date.now() - startTime < maxWait) {
            const gameInfo = await this.contract.getGameInfo(gameId);
            
            if (gameInfo.isFinalized) {
                console.log(`🎉 Game ${gameId} finalized by Chainlink!`);
                // Notify players they can claim prizes
                await this.notifyWinners(gameId);
                return true;
            }
            
            await new Promise(resolve => setTimeout(resolve, 10000)); // Check every 10s
        }
        
        console.warn(`⚠️ Game ${gameId} not finalized after ${maxWaitSeconds}s`);
        await this.sendAlert(`Game ${gameId} finalization delayed`);
        return false;
    }
    
    // Get player scores from your database
    async getPlayerScores(gameId) {
        // Your implementation: query your database for final scores
        // Example:
        // return await db.query('SELECT address, score FROM game_results WHERE game_id = ?', [gameId]);
        
        // Mock implementation:
        return [
            { address: '0x123...', score: 850 },
            { address: '0x456...', score: 720 },
            // ...
        ];
    }
    
    async notifyWinners(gameId) {
        // Send notifications to winners that prizes are claimable
        console.log(`Notifying winners of game ${gameId}...`);
    }
    
    async sendAlert(message) {
        // Your alerting system (email, Slack, etc.)
        console.error("ALERT:", message);
    }
}

// Usage
const manager = new TriviaGameManager(
    process.env.CONTRACT_ADDRESS,
    provider,
    signer
);

// Create game on-demand

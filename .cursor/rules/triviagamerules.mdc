## Frontend Integration

### 1. React Hook for Game State

```typescript
// hooks/useTriviaGame.ts
import { useState, useEffect } from 'react';
import { useContract, useContractRead, useContractWrite } from 'wagmi';

export function useTriviaGame(contractAddress: string) {
    const [gameState, setGameState] = useState({
        currentGameId: 0,
        timeRemaining: 0,
        playerCount: 0,
        prizePool: 0,
        isActive: false
    });

    // Read current game info
    const { data: currentGameId } = useContractRead({
        address: contractAddress,
        abi: TRIVIA_ABI,
        functionName: 'currentGameId',
        watch: true
    });

    const { data: timeRemaining } = useContractRead({
        address: contractAddress,
        abi: TRIVIA_ABI,
        functionName: 'getTimeRemaining',
        watch: true
    });

    // Enter game function
    const { write: enterGame, isLoading: isEntering } = useContractWrite({
        address: contractAddress,
        abi: TRIVIA_ABI,
        functionName: 'enterGame'
    });

    // Claim prize function
    const { write: claimPrize, isLoading: isClaiming } = useContractWrite({
        address: contractAddress,
        abi: TRIVIA_ABI,
        functionName: 'claimPrize'
    });

    return {
        gameState,
        enterGame,
        claimPrize,
        isEntering,
        isClaiming
    };
}
```

